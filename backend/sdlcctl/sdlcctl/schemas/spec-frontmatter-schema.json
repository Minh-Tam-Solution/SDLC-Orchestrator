{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdlc-orchestrator.dev/schemas/spec-frontmatter.json",
  "title": "SDLC 6.0.5 Specification Frontmatter Schema",
  "description": "JSON Schema for validating YAML frontmatter in SDLC 6.0.5 specification documents (SPEC-0002 compliant)",
  "type": "object",
  "required": [
    "spec_id",
    "title",
    "version",
    "status",
    "tier",
    "owner",
    "last_updated"
  ],
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^SPEC-[0-9]{4}$",
      "description": "Unique specification identifier (e.g., SPEC-0002)",
      "examples": ["SPEC-0001", "SPEC-0002", "SPEC-0100"]
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Human-readable specification title"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic versioning (major.minor.patch)",
      "examples": ["1.0.0", "2.1.3"]
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "REVIEW", "APPROVED", "ACTIVE", "DEPRECATED"],
      "description": "Specification lifecycle status"
    },
    "tier": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["LITE", "STANDARD", "PROFESSIONAL", "ENTERPRISE"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        {
          "type": "string",
          "enum": ["LITE", "STANDARD", "PROFESSIONAL", "ENTERPRISE"]
        }
      ],
      "description": "Applicable tiers for this specification"
    },
    "pillar": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(Pillar [0-7]|Section [0-9]+).*$"
          },
          "minItems": 1
        },
        {
          "type": "string",
          "pattern": "^(Pillar [0-7]|Section [0-9]+).*$"
        }
      ],
      "description": "Framework pillar or section reference"
    },
    "owner": {
      "type": "string",
      "minLength": 2,
      "description": "Specification owner (person, team, or role)"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Last update date in ISO format (YYYY-MM-DD)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "minLength": 2,
        "maxLength": 50
      },
      "uniqueItems": true,
      "description": "Categorization tags (lowercase, hyphenated)"
    },
    "related_adrs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADR-[0-9]{3}.*$"
      },
      "uniqueItems": true,
      "description": "Related Architecture Decision Records"
    },
    "related_specs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SPEC-[0-9]{4}$"
      },
      "uniqueItems": true,
      "description": "Related specifications"
    },
    "author": {
      "type": "string",
      "description": "Original author (if different from owner)"
    },
    "created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Creation date in ISO format (YYYY-MM-DD)"
    },
    "epic": {
      "type": "string",
      "pattern": "^EP-[0-9]+.*$",
      "description": "Related epic reference"
    },
    "sprint": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      ],
      "description": "Sprint number when created/updated"
    }
  },
  "additionalProperties": true
}
