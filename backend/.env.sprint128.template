# ============================================================================
# Sprint 128 - Team Invitation System Environment Variables
# ============================================================================
#
# Copy this file to .env.local and fill in the values
#
# Usage:
#   cp .env.sprint128.template .env.local
#   nano .env.local  # Edit with your actual values
#
# Reference: docs/06-deploy/runbooks/SENDGRID-SETUP-GUIDE.md
#            docs/06-deploy/runbooks/REDIS-SETUP-GUIDE.md
#
# ============================================================================

# ============================================================================
# Email Service (SendGrid)
# ============================================================================

# SendGrid API Key (Get from: https://app.sendgrid.com/settings/api_keys)
# Format: SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=""

# Sender Email (Must be verified in SendGrid dashboard)
# Go to: Settings → Sender Authentication → Single Sender Verification
SENDGRID_FROM_EMAIL="noreply@sdlc-orchestrator.com"

# Sender Display Name (shown in email "From" field)
SENDGRID_FROM_NAME="SDLC Orchestrator"

# ============================================================================
# Frontend URLs (for email links)
# ============================================================================

# Base frontend URL (no trailing slash)
FRONTEND_URL="http://localhost:3000"

# Invitation acceptance page URL
# Token will be appended: {INVITATION_ACCEPT_URL}?token=xxx
INVITATION_ACCEPT_URL="http://localhost:3000/invitations/accept"

# ============================================================================
# Redis Configuration (for rate limiting)
# ============================================================================

# Redis connection URL
# Format: redis://[username]:[password@]host:port/database
# Examples:
#   Local: redis://localhost:6379/0
#   With password: redis://:mypassword@localhost:6379/0
#   AWS ElastiCache: redis://my-cluster.cache.amazonaws.com:6379/0
#   Upstash: rediss://default:password@endpoint.upstash.io:6379
REDIS_URL="redis://localhost:6379/0"

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5

# ============================================================================
# Invitation Settings
# ============================================================================

# How long invitations remain valid (days)
# Default: 7 days
INVITATION_EXPIRY_DAYS=7

# ============================================================================
# Rate Limiting Settings
# ============================================================================

# Maximum invitations per team per hour (sliding window)
# Prevents spam from individual teams
# Default: 50 invitations/hour
MAX_INVITATIONS_PER_TEAM_PER_HOUR=50

# Maximum invitations to same email per day (across all teams)
# Prevents harassment via spam invitations
# Default: 3 invitations/day
MAX_INVITATIONS_PER_EMAIL_PER_DAY=3

# Maximum times an invitation can be resent
# Prevents abuse of resend feature
# Default: 3 resends
MAX_INVITATION_RESENDS=3

# Cooldown period between resends (minutes)
# Prevents rapid-fire resending
# Default: 5 minutes
INVITATION_RESEND_COOLDOWN_MINUTES=5

# ============================================================================
# Database Configuration (existing, should already be set)
# ============================================================================

# PostgreSQL connection string (should already exist in your .env)
# DATABASE_URL="postgresql://user:password@localhost:5432/sdlc_orchestrator"

# ============================================================================
# Testing Configuration (optional)
# ============================================================================

# Email address for receiving test emails
# Used by: python scripts/test_sendgrid.py
TEST_EMAIL=""

# Enable email sandbox mode (development only)
# When true, emails are logged instead of sent
# Default: false (send real emails)
EMAIL_SANDBOX_MODE=false

# ============================================================================
# Security Configuration (optional)
# ============================================================================

# JWT secret key for authentication (should already exist)
# SECRET_KEY="your-secret-key-here"

# JWT token expiry (minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# ============================================================================
# Monitoring & Logging (optional)
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable email delivery logging
LOG_EMAIL_DELIVERY=true

# Enable rate limiting logging
LOG_RATE_LIMITING=true

# ============================================================================
# Production Configuration (staging/production only)
# ============================================================================

# Production domain (for SendGrid domain authentication)
# PRODUCTION_DOMAIN="sdlc-orchestrator.com"

# AWS Secrets Manager ARN (for production secrets)
# AWS_SECRETS_ARN="arn:aws:secretsmanager:us-east-1:123456789012:secret:sdlc/sendgrid"

# ============================================================================
# NOTES
# ============================================================================
#
# 1. SendGrid Setup:
#    - Create account: https://sendgrid.com/
#    - Verify sender email (required)
#    - Generate API key with "Mail Send" permissions
#    - Free tier: 100 emails/day
#
# 2. Redis Setup:
#    - Docker: docker run -d -p 6379:6379 redis:7.2-alpine
#    - Or use existing Redis instance
#    - Test: redis-cli -h localhost -p 6379 ping
#
# 3. Rate Limiting:
#    - Team limit: 50/hour prevents spam
#    - Email limit: 3/day prevents harassment
#    - Cooldown: 5 minutes prevents rapid resending
#
# 4. Security:
#    - NEVER commit .env.local to git (.gitignore should exclude it)
#    - Use AWS Secrets Manager or HashiCorp Vault in production
#    - Rotate SendGrid API key every 90 days
#
# 5. Testing:
#    - Run: python scripts/test_sendgrid.py
#    - Run: python scripts/test_redis.py
#    - Check logs for any errors
#
# ============================================================================
