# ============================================================================
# SDLC Orchestrator — SME Pilot Environment Variables
# Sprint 201 Track C: Self-Hosted Pilot
#
# Instructions:
#   1. Copy this file: cp .env.example .env
#   2. Fill in REQUIRED values below (marked with CHANGE_ME)
#   3. Run: docker compose -f docker-compose.pilot.yml up -d
#   4. Access: http://localhost:3000 (dashboard) or Telegram bot
# ============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=sdlc_orchestrator
POSTGRES_USER=sdlc_user
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_min_16_chars

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_min_16_chars

# ── JWT Secret (min 32 characters) ──────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_key_min_32_characters_long

# ── MinIO (Evidence Vault) ──────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_min_12_chars

# ── OTT Channels ────────────────────────────────────────────────────────────
# Telegram: Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Zalo OA: Get from Zalo Open Platform (https://developers.zalo.me/)
ZALO_OA_ACCESS_TOKEN=

# HMAC verification for webhook security (recommended: true in production)
OTT_HMAC_ENABLED=true

# ── AI Provider (Ollama) ────────────────────────────────────────────────────
# Point to your Ollama instance (local GPU or remote)
# Local: http://host.docker.internal:11434
# Remote: http://your-gpu-server:11434
OLLAMA_URL=http://host.docker.internal:11434
CODEGEN_OLLAMA_URL=http://host.docker.internal:11434

# ── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8300/api/v1
ALLOWED_ORIGINS=http://localhost:3000

# ── Ports (change if conflicts) ─────────────────────────────────────────────
BACKEND_PORT=8300
FRONTEND_PORT=3000

# ── Security ────────────────────────────────────────────────────────────────
COOKIE_SECURE=false
# Set to true if using HTTPS (recommended for production)

# ── Docker Images (override for private registry) ───────────────────────────
# SDLC_BACKEND_IMAGE=ghcr.io/minh-tam-solution/sdlc-orchestrator-backend:latest
# SDLC_FRONTEND_IMAGE=ghcr.io/minh-tam-solution/sdlc-orchestrator-frontend:latest
