            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              },
              "scaleDistribution": {
                "type": "linear"
              }
            }
          }
        },
        "options": {
          "calculate": false,
          "yAxis": {
            "unit": "s"
          },
          "color": {
            "mode": "scheme",
            "scheme": "Spectral",
            "steps": 64,
            "reverse": true
          },
          "cellGap": 1,
          "legend": {
            "show": true
          },
          "tooltip": {
            "show": true,
            "yHistogram": true
          }
        }
      },
      {
        "id": 14,
        "title": "❌ Failures & Errors",
        "type": "row",
        "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 15,
        "title": "Failures by Channel",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(notification_failures_total[5m])) by (channel)",
            "legendFormat": "{{channel}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "fillOpacity": 30,
              "showPoints": "auto",
              "pointSize": 4
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["sum", "mean"]
          }
        }
      },
      {
        "id": 16,
        "title": "Failure Reasons (24h)",
        "type": "table",
        "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(increase(notification_failures_total[24h])) by (channel, failure_reason)",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto"
            }
          }
        },
        "options": {
          "showHeader": true,
          "sortBy": [{"displayName": "Count", "desc": true}]
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true},
              "renameByName": {
                "channel": "Channel",
                "failure_reason": "Reason",
                "Value": "Count"
              }
            }
          }
        ]
      },
      {
        "id": 17,
        "title": "🚪 Gate Metrics",
        "type": "row",
        "gridPos": {"x": 0, "y": 32, "w": 24, "h": 1},
