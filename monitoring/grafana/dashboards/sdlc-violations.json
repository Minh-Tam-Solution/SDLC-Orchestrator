{
  "dashboard": {
    "id": null,
    "uid": "sdlc-violations",
    "title": "SDLC Orchestrator - Violations & Evidence",
    "description": "Sprint 22 Day 3: Violation trends by severity, category, project; Evidence upload metrics",
    "tags": ["sdlc-orchestrator", "violations", "evidence", "security", "sprint-22"],
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 1,
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "🚨 Violations Overview",
        "type": "row",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
        "collapsed": false
      },
      {
        "id": 2,
        "title": "Total Violations (24h)",
        "type": "stat",
        "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "sum(increase(compliance_violations_total[24h]))",
            "legendFormat": "Total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 20},
                {"color": "orange", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "colorMode": "background",
          "graphMode": "area"
        }
      },
